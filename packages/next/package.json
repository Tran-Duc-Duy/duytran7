{
  "name": "@duytran7/landing-next",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --config ../../vitest.config.ts",
    "ci:publish": "pnpm publish --access public --no-git-checks",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@duytran7/landing-core": "workspace:*",
    "@duytran7/landing-components": "workspace:*",
    "framer-motion": "^11.15.0"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tran-Duc-Duy/duytran7.git",
    "directory": "packages/next"
  },
  "license": "MIT",
  "keywords": [
    "landing",
    "nextjs",
    "seo",
    "metadata",
    "json-config"
  ],
  "description": "Next.js adapter: buildMetadata, JsonLd, LandingPage from JSON config. Use with @duytran7/landing-core and @duytran7/landing-components."
}