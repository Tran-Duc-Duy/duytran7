{
  "name": "@duytran7/landing-core",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --config ../../vitest.config.ts",
    "ci:publish": "pnpm publish --access public --no-git-checks",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~5.7.2"
  },
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/Tran-Duc-Duy/duytran7.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "keywords": [
    "landing",
    "config",
    "schema",
    "zod",
    "typescript"
  ],
  "description": "Types, Zod schema, parser and component registry for landing page JSON config. Framework-agnostic."
}